# Salin ke .env lalu sesuaikan
PORT=3000
HOST=127.0.0.1
SESSION_SECRET=ubah-ini-menjadi-rahasia-panjang-yang-acak
NODE_ENV=development

# PostgreSQL — backend database (multi-user).
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Contoh produksi: postgres://sikeu:passwordkuat@db-server:5432/sikeu
DATABASE_URL=postgres://sikeu:sikeu@127.0.0.1:5432/sikeu

# Untuk menjalankan test (npm test): database terpisah agar data dev tidak tersentuh.
# TEST_DATABASE_URL=postgres://sikeu:sikeu@127.0.0.1:5432/sikeu_test
