# Salin ke `.env` DI VPS (di folder repo), lalu isi nilai sebenarnya.
# JANGAN commit berkas .env — sudah masuk .gitignore.
# Dibaca oleh docker-compose.yml.

# Domain publik aplikasi (arahkan A record DNS ke IP VPS lebih dulu).
DOMAIN=sikeu.tazkia.ac.id

# Port loopback host tempat app diterbitkan (dipakai reverse proxy yang sudah ada).
# Ganti bila 3000 sudah terpakai di server. Hanya relevan pada mode "di belakang proxy".
APP_PORT=3000

# Email untuk Let's Encrypt (opsional; lihat komentar di deploy/Caddyfile).
ACME_EMAIL=admin@tazkia.ac.id

# PostgreSQL (dibuat otomatis oleh container db).
POSTGRES_USER=sikeu
POSTGRES_PASSWORD=ISI-PASSWORD-KUAT-DI-SINI
POSTGRES_DB=sikeu

# Rahasia sesi — WAJIB acak & panjang. Hasilkan dengan:
#   openssl rand -hex 32
SESSION_SECRET=ISI-STRING-ACAK-64-KARAKTER-DI-SINI

# (Opsional) Image aplikasi. Default menarik dari GHCR (alur CI).
# Kosongkan/ubah bila memakai build lokal di VPS atau tag versi tertentu.
# APP_IMAGE=ghcr.io/galihsidik86/sikeu-tazkia:latest
